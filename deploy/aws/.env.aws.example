# AWS account
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012

# ECR repositories (names only)
ECR_BACKEND_REPO=devboard-backend
ECR_FRONTEND_REPO=devboard-frontend

# Runtime image tags generated during deploy
# BACKEND_IMAGE=
# FRONTEND_IMAGE=

# EC2 target
EC2_HOST=ec2-xx-xx-xx-xx.compute-1.amazonaws.com
EC2_USER=ec2-user
EC2_SSH_KEY_PATH=~/.ssh/devboard.pem
EC2_DEPLOY_PATH=/opt/devboard

# Public app settings
FRONTEND_PORT=80
VITE_API_URL=/api/v1
CORS_ALLOWED_ORIGINS=https://app.example.com

# RDS PostgreSQL
RDS_HOST=your-rds.cluster-xxxx.eu-central-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=devboard
RDS_USER=devboard
RDS_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# JWT
JWT_ISSUER=devboard-api
JWT_AUDIENCE=devboard-client
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRATION_MINUTES=1440
